# Advanti env vars — copy to .env.local for local dev or set on Vercel for prod.

# ─── Resend (transactional + newsletter) ───────────────────────────────────────
# Get from https://resend.com/api-keys after creating an account.
# Required for: newsletter signup, welcome email, drip sequence, gated lead
# magnets, verdivurdering intake. The whole funnel system is dead without this.
RESEND_API_KEY=

# Audience ID for the main Advanti newsletter list (UUID).
# Create at https://resend.com/audiences. Every signup gets added here.
RESEND_AUDIENCE_ID=

# Verified sender — must be from a domain you've verified in Resend.
# Format: "Advanti Estate <hei@advantiestate.no>"
EMAIL_FROM=

# ─── Discord (team-side lead notifications) ────────────────────────────────────
# Webhook for the team's lead-flow channel. Already in use by /sjekkliste-
# verdivurdering and the kontakt form; now enriched with signup source +
# lead-magnet context.
DISCORD_WEBHOOK_URL=

# ─── GTM (already in use) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
