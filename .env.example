# Advanti env vars — copy to .env.local for local dev or set on Vercel for prod.

# ─── Resend (transactional + newsletter) ───────────────────────────────────────
# Get from https://resend.com/api-keys after creating an account.
# Required for: newsletter signup, welcome email, drip sequence, gated lead
# magnets, verdivurdering intake. The whole funnel system is dead without this.
RESEND_API_KEY=

# Audience ID for the main Advanti newsletter list (UUID).
# Create at https://resend.com/audiences. Every signup gets added here.
RESEND_AUDIENCE_ID=

# Verified sender — must be from a domain you've verified in Resend.
# Format: "Advanti Estate <hei@advantiestate.no>"
EMAIL_FROM=

# ─── Supabase (lead-capture CRM sink) ──────────────────────────────────────────
# Project credentials from Supabase Dashboard → Settings → API.
# Each signup writes one row to the `leads` table (see
# supabase/migrations/001_leads.sql). Resend is still the source of truth for
# "is this email on the newsletter list?"; Supabase is the team's CRM sink —
# query it from the Supabase dashboard or export to a real CRM later.
SUPABASE_URL=
# IMPORTANT: service_role key (server-side only, bypasses RLS). NEVER the
# anon key. NEVER expose this in client code, public env vars, or git.
SUPABASE_SERVICE_ROLE_KEY=
# Public values — safe to expose client-side. Needed for Supabase Storage CDN
# images (public `imagebank` bucket) and any client-side Supabase SDK use.
NEXT_PUBLIC_SUPABASE_URL=
# Modern publishable key (sb_publishable_...). Replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Discord (team-side lead notifications) ────────────────────────────────────
# Webhook for the team's lead-flow channel. Already in use by /sjekkliste-
# verdivurdering and the kontakt form; now enriched with signup source +
# lead-magnet context.
DISCORD_WEBHOOK_URL=

# ─── GTM (already in use) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
